{
  "name": "nyc-property-records-platform",
  "version": "1.0.0",
  "description": "NYC Property-Records Search Platform — NYC Open Data → Verified Reports",
  "private": true,
  "type": "module",
  "main": "dist/workers/search-worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler types && tsc -p tsconfig.json",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "db:init": "wrangler d1 execute property-records-db --file=./schema.sql --remote"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "typescript": "^5.4.5",
    "wrangler": "^3.60.0",
    "vitest": "^1.6.0"
  }
}
